# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
FIREBASE_ADMIN_SDK=

# YouTube Data API v3
YOUTUBE_API_KEY=

# 서비스 배포 URL (SEO, sitemap, OG 태그에 사용)
NEXT_PUBLIC_BASE_URL=

# Naver Site Verification
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=

# Google AdSense (승인 후 입력)
# Publisher ID: AdSense 콘솔 → 계정 → 게시자 ID (ca-pub-으로 시작)
NEXT_PUBLIC_ADSENSE_CLIENT=
# Ad Slot ID: AdSense 콘솔 → 광고 → 광고 단위 → 단위 코드의 data-ad-slot 값
NEXT_PUBLIC_ADSENSE_SLOT_DASHBOARD=
NEXT_PUBLIC_ADSENSE_SLOT_COLLECTIONS=
NEXT_PUBLIC_ADSENSE_SLOT_SHARE=
